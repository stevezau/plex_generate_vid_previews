# =============================================================================
# Plex Generate Previews — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Most settings can be configured via the web UI instead; env vars are
# optional overrides. See docs/reference.md for full documentation.
# =============================================================================

# -- Plex Connection ----------------------------------------------------------
# Usually set via the Setup Wizard (Plex OAuth). Only needed for CLI-only runs.
# PLEX_URL=http://192.168.1.100:32400
# PLEX_TOKEN=your-plex-token
# PLEX_CONFIG_FOLDER=/plex

# -- Processing ---------------------------------------------------------------
# GPU_THREADS=1
# CPU_THREADS=1
# FALLBACK_CPU_THREADS=0
# FFMPEG_THREADS=2
# THUMBNAIL_QUALITY=4
# PLEX_BIF_FRAME_INTERVAL=5
# REGENERATE_THUMBNAILS=false
# PLEX_LIBRARIES=Movies,TV Shows
# SORT_BY=newest

# -- Web Interface ------------------------------------------------------------
# WEB_PORT=8080
# WEB_AUTH_TOKEN=your-secret-token
# FLASK_SECRET_KEY=your-flask-secret
# CORS_ORIGINS=*

# -- Docker / Permissions -----------------------------------------------------
# PUID=1000
# PGID=1000
# TZ=America/New_York

# -- System -------------------------------------------------------------------
# TMP_FOLDER=/tmp
# LOG_LEVEL=INFO
# LOG_FORMAT=pretty
# DEBUG=false
# PLEX_TIMEOUT=60

# -- Security (path restrictions) ---------------------------------------------
# PLEX_DATA_ROOT=/plex
# MEDIA_ROOT=/
