# =============================================================================
# Plex Generate Previews — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#
# INFRASTRUCTURE (always active):
#   These control how the app runs. Set as needed.
#
# APPLICATION SETTINGS (migration only):
#   PLEX_URL, PLEX_TOKEN, CPU_THREADS, etc. act as one-time seed values.
#   On first startup, they are migrated into settings.json. After that,
#   settings.json is the single source of truth. Configure via the web UI
#   Settings page.
# =============================================================================

# -- Infrastructure (always active) -------------------------------------------
# CONFIG_DIR=/config
# WEB_PORT=8080
# PUID=1000
# PGID=1000
# TZ=America/New_York
# CORS_ORIGINS=*
# HTTPS=false
# DEV_RELOAD=false
